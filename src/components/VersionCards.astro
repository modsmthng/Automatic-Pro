---
import type { Family } from '../lib/releaseData';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const homeCardLogoMap: Record<string, string> = {
  v2: `${base}images/automatic-pro-v2-logo.png`,
  vit3: `${base}images/automatic-pro-v3-logo.png`,
};

interface Props {
  families: Family[];
}

const { families } = Astro.props as Props;
---

<div class="ap-version-grid">
  {
    families.map((family) => (
      <a class="ap-version-card" href={`${base}${family.slug}/`}>
        <div class="ap-version-card-main">
          <div class="ap-version-card-copy">
            <div class="ap-pill-row">
              <span class:list={['ap-pill', family.status === 'stable' ? 'ap-pill-stable' : 'ap-pill-testing']}>
                {family.status === 'stable' ? 'Stable' : 'In testing'}
              </span>
            </div>
            <h2>{family.displayName}</h2>
            {family.homeFeaturedLine && <p class="ap-version-featured-line">{family.homeFeaturedLine}</p>}
            <div class="ap-version-summary" set:html={family.summary} />
            <span class="ap-card-link">Go to version</span>
          </div>

          {homeCardLogoMap[family.slug] && (
            <div class="ap-version-card-logo-wrap">
              <img alt={`${family.displayName} logo`} class="ap-version-card-logo" src={homeCardLogoMap[family.slug]} />
            </div>
          )}
        </div>
      </a>
    ))
  }
</div>
