---
import type { Family } from '../lib/releaseData';
import {
  getCurrentDownloadGroups,
  getCurrentDownloads,
  getDownloadMetaLine,
  getDownloadPath,
  getLatestBuild,
} from '../lib/releaseData';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

interface Props {
  family: Family;
}

const { family } = Astro.props as Props;
const latestBuild = getLatestBuild(family);
const currentDownloads = getCurrentDownloads(family);
const currentDownloadGroups = family.slug === 'vit3' ? getCurrentDownloadGroups(family) : [];
---

<section class="ap-family-hero">
  <div>
    <div class="ap-pill-row">
      <span class:list={['ap-pill', family.status === 'stable' ? 'ap-pill-stable' : 'ap-pill-testing']}>
        {family.status === 'stable' ? 'Stable' : 'In testing'}
      </span>
    </div>
    <p class="ap-family-summary">{family.summary}</p>
    {
      family.futureDisplayName !== family.displayName && (
        <p class="ap-family-note">This family will be promoted to {family.futureDisplayName} once testing is complete.</p>
      )
    }
    <p class="ap-family-note">
      {family.status === 'stable'
        ? `Current stable build: ${latestBuild.buildVersion}.`
        : `Latest family update: ${latestBuild.buildVersion}. Variants that were not touched in the latest update keep their older build number until their next revision.`}
    </p>
  </div>

  <figure class="ap-photo-card ap-photo-card-tight">
    <img alt="Espresso in a cup" class="ap-photo-card-image" src={`${base}images/espresso.jpg`} />
  </figure>
</section>

<section class="ap-family-section">
  <div class="ap-section-header ap-section-header-stack">
    <div>
      <p class="ap-kicker">Downloads</p>
      <h2>Variations</h2>
    </div>
    <p>
      {family.status === 'stable'
        ? 'Current files for the active stable build.'
        : family.slug === 'vit3'
          ? 'Latest available file for each currently published profile type and dose.'
          : 'Latest available file for each currently published variant.'}
    </p>
  </div>

  {
    family.slug === 'vit3' ? (
      <>
        <nav class="ap-profile-type-nav" aria-label="Profile types">
          {currentDownloadGroups.map((group) => (
            <a
              class:list={['ap-profile-type-card', group.downloads.length === 0 && 'ap-profile-type-card-empty']}
              href={`#${group.sectionId}`}
            >
              <div class="ap-profile-type-title-row">
                <h3>{group.label}</h3>
                {group.downloads.length === 0 && <span class="ap-profile-type-empty">No standalone files</span>}
              </div>
              <p>{group.description || 'Experimental variants are currently listed inside their matching main profile type.'}</p>
              {group.note && <p class="ap-profile-type-note">{group.note}</p>}
            </a>
          ))}
        </nav>

        <div class="ap-profile-type-sections">
          {currentDownloadGroups.map((group) => (
            <section class="ap-profile-type-section" id={group.sectionId}>
              <div class="ap-section-header ap-section-header-stack">
                <div>
                  <h3>{group.label}</h3>
                </div>
                <p>{group.description || 'Experimental variants are currently listed inside their matching main profile type.'}</p>
              </div>
              {group.note && <p class="ap-profile-type-note ap-profile-type-note-section">{group.note}</p>}

              {group.downloads.length > 0 ? (
                <ul class="ap-download-list">
                  {group.downloads.map((download) => (
                    <li class="ap-download-row">
                      <div class="ap-download-copy">
                        <div class="ap-download-title-row">
                          <h3>{download.label}</h3>
                          {family.status === 'testing' && <span class="ap-build-tag">{download.buildVersion}</span>}
                        </div>
                        <p class="ap-download-variant">{getDownloadMetaLine(download.variant, download.temperatureC)}</p>
                        {download.notes && <p class="ap-download-notes">{download.notes}</p>}
                      </div>

                      <a
                        class="ap-button ap-button-primary"
                        download
                        href={`${base}${getDownloadPath(family.slug, download.buildVersion, download.file)}`}
                      >
                        Download JSON
                      </a>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="ap-profile-type-empty-note">
                  No standalone files in the current build. Experimental variants are currently listed inside their
                  matching main profile type.
                </p>
              )}
            </section>
          ))}
        </div>
      </>
    ) : (
      <ul class="ap-download-list">
        {currentDownloads.map((download) => (
          <li class="ap-download-row">
            <div class="ap-download-copy">
              <div class="ap-download-title-row">
                <h3>{download.label}</h3>
                {family.status === 'testing' && <span class="ap-build-tag">{download.buildVersion}</span>}
              </div>
              <p class="ap-download-variant">{getDownloadMetaLine(download.variant, download.temperatureC)}</p>
              {download.notes && <p class="ap-download-notes">{download.notes}</p>}
            </div>

            <a
              class="ap-button ap-button-primary"
              download
              href={`${base}${getDownloadPath(family.slug, download.buildVersion, download.file)}`}
            >
              Download JSON
            </a>
          </li>
        ))}
      </ul>
    )
  }
</section>
