---
import type { Family } from '../lib/releaseData';
import {
  getCurrentDownloadGroups,
  getCurrentDownloads,
  getDownloadMetaLine,
  getDownloadPath,
  getLatestBuild,
} from '../lib/releaseData';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const directLeverImagePath = `${base}images/direct-lever.png`;
const springLeverImagePath = `${base}images/spring-lever.png`;

interface Props {
  family: Family;
}

const { family } = Astro.props as Props;
const latestBuild = getLatestBuild(family);
const currentDownloads = getCurrentDownloads(family);
const currentDownloadGroups = family.downloadMode === 'batched' ? getCurrentDownloadGroups(family) : [];
const hasPublishedBuilds = family.builds.length > 0;
const highlightFeaturedGroups = !['vit3', 'lab'].includes(family.slug);

function getProfileTypeImage(groupType: string) {
  if (groupType === 'direct-lever') {
    return directLeverImagePath;
  }

  if (groupType === 'spring-lever') {
    return springLeverImagePath;
  }

  return '';
}
---

<section class="ap-family-hero">
  <div>
    <div class="ap-pill-row">
      <span class:list={['ap-pill', family.status === 'stable' ? 'ap-pill-stable' : 'ap-pill-testing']}>
        {family.status === 'stable' ? 'Stable' : 'In testing'}
      </span>
    </div>
    <div class="ap-family-summary" set:html={family.summary} />
    <p class="ap-family-note">
      {!latestBuild
        ? 'No published builds yet.'
        : family.status === 'stable'
          ? `Current stable build: ${latestBuild.buildVersion}.`
          : `Latest family update: ${latestBuild.buildVersion}.`}
    </p>
  </div>

  <figure class="ap-photo-card ap-photo-card-tight">
    <img alt="Espresso in a cup" class="ap-photo-card-image" src={`${base}images/espresso.jpg`} />
  </figure>
</section>

<section class="ap-family-section">
  <div class="ap-section-header ap-section-header-stack">
    <div>
      <p class="ap-kicker">Downloads</p>
      <h2>Variations</h2>
    </div>
    <p>
      {!hasPublishedBuilds
        ? 'No published files yet.'
        : family.status === 'stable'
          ? 'Current files for the active stable build.'
          : family.downloadMode === 'batched'
            ? 'Latest available file for each currently published profile type and dose.'
            : 'Latest available file for each currently published variant.'}
    </p>
  </div>

  {
    family.downloadMode === 'batched' ? (
      <>
        <nav class="ap-profile-type-nav" aria-label="Profile types">
          {currentDownloadGroups.map((group) => (
            <a
              class:list={[
                'ap-profile-type-card',
                highlightFeaturedGroups && group.featured && 'ap-profile-type-card-featured',
                group.downloads.length === 0 && 'ap-profile-type-card-empty',
              ]}
              href={`#${group.sectionId}`}
            >
              <div class="ap-profile-type-card-copy">
                <div class="ap-profile-type-highlight-row">
                  <div>
                    <div class="ap-profile-type-title-row">
                      <h3>{group.label}</h3>
                    </div>

                    {group.featuredLine && <p class="ap-profile-type-featured-line">{group.featuredLine}</p>}
                  </div>

                  {getProfileTypeImage(group.type) && (
                    <img
                      alt={`${group.label} icon`}
                      class="ap-profile-type-icon"
                      loading="lazy"
                      src={getProfileTypeImage(group.type)}
                    />
                  )}
                </div>
              </div>
            </a>
          ))}
        </nav>

        <div class="ap-profile-type-sections">
          {currentDownloadGroups.map((group) => (
            <section class="ap-profile-type-section" id={group.sectionId}>
              <div class="ap-section-header ap-section-header-stack">
                <div>
                  <div class="ap-profile-type-highlight-row ap-profile-type-highlight-row-section">
                    <div>
                      <div class="ap-profile-type-heading-row">
                        <h3>{group.label}</h3>
                      </div>
                      {group.featuredLine && (
                        <p class="ap-profile-type-featured-line ap-profile-type-featured-line-section">{group.featuredLine}</p>
                      )}
                    </div>

                    {getProfileTypeImage(group.type) && (
                      <img
                        alt={`${group.label} icon`}
                        class="ap-profile-type-icon ap-profile-type-icon-large"
                        loading="lazy"
                        src={getProfileTypeImage(group.type)}
                      />
                    )}
                  </div>
                </div>
              </div>

              <details class="ap-profile-type-details">
                <summary class="ap-profile-type-details-summary">More details</summary>
                <div class="ap-profile-type-details-copy">
                  <p>{group.description || 'Experimental variants are currently listed inside their matching main profile type.'}</p>
                  {group.note && <p class="ap-profile-type-note ap-profile-type-note-section">{group.note}</p>}
                </div>
              </details>

              {group.downloads.length > 0 ? (
                <ul class="ap-download-list">
                  {group.downloads.map((download) => (
                    <li class="ap-download-row">
                      <div class="ap-download-copy">
                        <div class="ap-download-title-row">
                          <h3>{download.label}</h3>
                          {family.status === 'testing' && <span class="ap-build-tag">{download.buildVersion}</span>}
                        </div>
                        <p class="ap-download-variant">{getDownloadMetaLine(download.variant, download.temperatureC)}</p>
                        {download.notes && <p class="ap-download-notes">{download.notes}</p>}
                      </div>

                      <a
                        class="ap-button ap-button-primary"
                        download
                        href={`${base}${getDownloadPath(family.slug, download.buildVersion, download.file)}`}
                      >
                        Download JSON
                      </a>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="ap-profile-type-empty-note">
                  {hasPublishedBuilds ? 'No standalone files in the current build.' : 'No published files yet for this variation.'}
                </p>
              )}
            </section>
          ))}
        </div>
      </>
    ) : (
      currentDownloads.length > 0 ? (
        <ul class="ap-download-list">
          {currentDownloads.map((download) => (
            <li class="ap-download-row">
              <div class="ap-download-copy">
                <div class="ap-download-title-row">
                  <h3>{download.label}</h3>
                  {family.status === 'testing' && <span class="ap-build-tag">{download.buildVersion}</span>}
                </div>
                <p class="ap-download-variant">{getDownloadMetaLine(download.variant, download.temperatureC)}</p>
                {download.notes && <p class="ap-download-notes">{download.notes}</p>}
              </div>

              <a
                class="ap-button ap-button-primary"
                download
                href={`${base}${getDownloadPath(family.slug, download.buildVersion, download.file)}`}
              >
                Download JSON
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="ap-profile-type-empty-note">No published files yet.</p>
      )
    )
  }
</section>
